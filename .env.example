# ============================================
# Nafarrock - Variables de entorno
# Copiar a .env y completar con tus valores reales
# ============================================

# Base de datos (Railway / Supabase / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generar-con-openssl-rand-base64-32"

# OAuth - Google (Continuar con Google)
# 1. Crear proyecto en https://console.cloud.google.com/
# 2. APIs & Services > Credentials > Create OAuth 2.0 Client ID
# 3. Tipo: Web application | Authorized redirect URIs: http://localhost:3000/api/auth/callback/google (dev) y https://tudominio.com/api/auth/callback/google (prod)
# 4. Copiar Client ID y Client Secret aquí
# AUTH_GOOGLE_ID=tu_client_id.apps.googleusercontent.com
# AUTH_GOOGLE_SECRET=tu_client_secret
# Poner "true" para mostrar el botón en Login/Registro (solo cuando AUTH_GOOGLE_ID y AUTH_GOOGLE_SECRET estén configurados)
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true

# Email (para magic link / verificación)
# EMAIL_SERVER_HOST=
# EMAIL_SERVER_PORT=
# EMAIL_FROM=

# Admin (obligatorio para seed - nunca incluyas credenciales en el código)
# ADMIN_EMAIL="tu-email@ejemplo.com"
# ADMIN_PASSWORD="tu-contraseña-segura"

# Cloudinary (gestión de imágenes)
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Spotify (autofill de bandas)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# Ticketmaster (descubrir eventos)
# TICKETMASTER_API_KEY=

# OpenAI (traducción de biografías)
# OPENAI_API_KEY=

# Resend (verificación de email)
# RESEND_API_KEY=

# Mapbox
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=